{
  "manifest_version": 3,
  "name": "Metafy Guide Translator 🇯🇵",
  "version": "1.0.0",
  "description": "Metafyのガイドページを自動で日本語に翻訳します",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://metafy.gg/*",
    "https://api.anthropic.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://metafy.gg/guides/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
